#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

MODE="${1:---all}"
case "$MODE" in --all|--staged) ;; *) echo "Usage: $0 [--all|--staged]" >&2; exit 64 ;; esac

require() {
  command -v "$1" >/dev/null 2>&1 || {
    printf 'Missing required tool: %s\n' "$1" >&2
    printf 'On macOS, install it with: brew install %s\n' "$1" >&2
    exit 69
  }
}

# Files a user is expected to run directly — MUST be committed executable (100755),
# because what is committed is what a fresh clone gets. The committed-mode check
# below reads the index (git ls-files -s), never the working tree (#83). Keep this
# list explicit: every tracked shell file carries a shebang, so a shebang cannot
# discriminate the one sourced file (lib/cleanup.sh) that is correctly 100644.
EXECUTABLE_FILES=(bin/system-health bin/install-schedule bin/configure-email scripts/check scripts/check-label-policy scripts/install-hooks scripts/install-quality-tools tests/smoke.sh .githooks/pre-commit .githooks/pre-push)
# Sourced, never executed — correctly non-executable (100644).
SOURCED_FILES=(lib/cleanup.sh)
# The bash -n and ShellCheck passes lint both sets; the mode check covers only the
# executables. One definition of each, consumed as their union — no duplication.
SHELL_FILES=("${EXECUTABLE_FILES[@]}" "${SOURCED_FILES[@]}")

assert_committed_modes() {
  # Fail fast if any file a user runs directly is committed non-executable. Reads the
  # INDEX (git ls-files -s), so it behaves identically under --all and --staged, a
  # `git update-index --chmod=+x` fix is honored without a commit, and the pre-commit
  # hook catches a mode regression at commit time (#83). Runs before the expensive
  # passes so the signal is immediate.
  local file mode failed=0
  for file in "${EXECUTABLE_FILES[@]}"; do
    mode="$(git ls-files -s -- "$file" | awk 'NR==1{print $1}')"
    if [[ -z "$mode" ]]; then
      printf 'Committed-mode check: expected-executable file is not tracked: %s\n' "$file" >&2
      failed=1
    elif [[ "$mode" != 100755 ]]; then
      printf 'Committed-mode check: %s is committed %s, expected 100755.\n' "$file" "$mode" >&2
      printf '  Fix: git update-index --chmod=+x %s\n' "$file" >&2
      failed=1
    fi
  done
  if [[ "$failed" -ne 0 ]]; then
    printf 'Committed executable-bit check failed (see the fix above); no other checks ran.\n' >&2
    exit 1
  fi
}

assert_spec_conformance() {
  # Every tracked artifacts/specs/*.md must open with the durable-contracts block, so a spec copied
  # from TEMPLATE.md inherits it (#67). TEMPLATE.md — the propagation source — must additionally
  # verify closure via the GraphQL closingIssuesReferences field and must NOT carry the body
  # text-match snippet that reports the broken `Closes #A, #B` form as correct (#99). Assertion 2 is
  # template-scoped on purpose: the 9 historical specs are immutable records that legitimately still
  # carry the old snippet, so gating them would produce a permanently red build with no legal fix
  # (a handed-off spec cannot be rewritten). Reads the tracked set via git ls-files, so it behaves
  # the same under --all and --staged and sees a freshly `git add`-ed file.
  local file failed=0 seen_template=0
  local template='artifacts/specs/TEMPLATE.md'
  while IFS= read -r file; do
    [[ -n "$file" ]] || continue
    if ! grep -qE '^##[[:space:]]+0\..*Read the durable contracts first' "$file"; then
      printf 'Spec-conformance check: %s is missing the "## 0. Read the durable contracts first" block.\n' "$file" >&2
      failed=1
    fi
    if [[ "$file" == "$template" ]]; then
      seen_template=1
      if ! grep -qF 'closingIssuesReferences' "$file"; then
        printf 'Spec-conformance check: %s must verify closure with the GraphQL closingIssuesReferences field.\n' "$file" >&2
        failed=1
      fi
      if grep -qF 'body|test("Closes' "$file"; then
        printf 'Spec-conformance check: %s must not use the body text-match closure snippet; use closingIssuesReferences (#99).\n' "$file" >&2
        failed=1
      fi
    fi
  done < <(git ls-files 'artifacts/specs/*.md')
  if [[ "$seen_template" -ne 1 ]]; then
    printf 'Spec-conformance check: %s must exist and be tracked (it is the spec propagation source).\n' "$template" >&2
    failed=1
  fi
  if [[ "$failed" -ne 0 ]]; then
    printf 'Spec-conformance check failed (see above); fix before committing.\n' >&2
    exit 1
  fi
}

printf '%s\n' 'Checking committed executable bits...'
assert_committed_modes

printf '%s\n' 'Checking spec conformance...'
assert_spec_conformance

printf '%s\n' 'Checking staged whitespace errors...'
git diff --cached --check
if [[ "$MODE" == --all ]]; then
  git diff --check
  if git rev-parse --verify HEAD >/dev/null 2>&1; then git show --check --format= HEAD; fi
fi
printf '%s\n' 'Checking Bash syntax...'
# Thread "$BASH" (the interpreter running this script) through the sub-checks so the
# whole gate uses ONE bash. In CI the entrypoint is `/bin/bash scripts/check --all`, which
# pins every layer — this syntax check and the smoke run below — to the system Bash 3.2 the
# project targets; a bare, PATH-resolved `bash` could be 5.x and would parse 3.2-incompatible
# constructs (mapfile, declare -A, ${v^^}) without complaint, defeating this very check (#81).
"$BASH" -n "${SHELL_FILES[@]}"
printf '%s\n' 'Running ShellCheck...'
require shellcheck
shellcheck "${SHELL_FILES[@]}"

printf '%s\n' 'Linting GitHub Actions workflows...'
require actionlint
actionlint

if command -v plutil >/dev/null 2>&1; then
  printf '%s\n' 'Validating LaunchAgent template...'
  plutil -lint config/io.github.system-health.report.plist.template
fi

printf '%s\n' 'Running smoke tests...'
"$BASH" tests/smoke.sh   # same interpreter as the syntax check above, not smoke.sh's own env-bash shebang (#81)

printf '%s\n' 'Scanning for secrets with Gitleaks...'
require gitleaks
if [[ "$MODE" == --staged ]]; then
  gitleaks git --pre-commit --redact --staged --verbose
else
  if git rev-parse --verify HEAD >/dev/null 2>&1; then
    gitleaks git --redact --verbose
  fi
  while IFS= read -r -d '' file; do
    [[ -f "$file" ]] || continue
    printf '\nFILE: %s\n' "$file"
    cat "$file"
  done < <(git ls-files -co --exclude-standard -z) | gitleaks stdin --redact --verbose
fi

printf '%s\n' 'All checks passed.'
