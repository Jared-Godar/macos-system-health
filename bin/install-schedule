#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
HEALTH_SCRIPT="$SCRIPT_DIR/system-health"
LABEL="io.github.system-health.report"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
LOG_DIR="${SYSTEM_HEALTH_LOG_DIR:-$HOME/Library/Logs/system-health}"
MAIL_TO="${SYSTEM_HEALTH_EMAIL:-}"
TEMPLATE="$SCRIPT_DIR/../config/io.github.system-health.report.plist.template"
TMP_PLIST="$PLIST.tmp.$$"

xml_escape() {
  local value="$1"
  value="${value//&/&amp;}"
  value="${value//</&lt;}"
  value="${value//>/&gt;}"
  printf '%s' "$value"
}

ESCAPED_SCRIPT="$(xml_escape "$HEALTH_SCRIPT")"
ESCAPED_LOG_DIR="$(xml_escape "$LOG_DIR")"
ESCAPED_EMAIL="$(xml_escape "$MAIL_TO")"

umask 077
mkdir -p "$(dirname "$PLIST")" "$LOG_DIR"
trap 'rm -f "$TMP_PLIST"' EXIT INT TERM
while IFS= read -r line || [[ -n "$line" ]]; do
  line="${line//__SCRIPT__/$ESCAPED_SCRIPT}"
  line="${line//__LOG_DIR__/$ESCAPED_LOG_DIR}"
  line="${line//__EMAIL__/$ESCAPED_EMAIL}"
  printf '%s\n' "$line"
done < "$TEMPLATE" > "$TMP_PLIST"
plutil -lint "$TMP_PLIST" >/dev/null
mv "$TMP_PLIST" "$PLIST"
launchctl bootout "gui/$UID/$LABEL" 2>/dev/null || true
launchctl bootstrap "gui/$UID" "$PLIST"
printf 'Installed weekly report: %s\n' "$PLIST"
